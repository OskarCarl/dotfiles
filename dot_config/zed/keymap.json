// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
	{
		"context": "Workspace",
		"bindings": {
			"shift shift": "file_finder::Toggle",
			"ctrl-shift-g": "git_panel::Toggle",
			"ctrl-alt-g": ["task::Spawn", { "task_name": "lazygit" }],
			"ctrl-shift-e": "project_panel::Toggle",
			"ctrl-shift-b": "outline_panel::Toggle",
			"ctrl-shift-d": "debug_panel::Toggle",
			"ctrl-shift-t": "terminal_panel::Toggle",
			"ctrl-shift-a": "agent::ToggleFocus",
			"ctrl-?": "agent::Toggle",
			"ctrl-shift-z": "workspace::ToggleZoom",
		},
	},
	{
		"context": "!Terminal",
		"bindings": {
			"ctrl-shift-c": "editor::Copy",
			"ctrl-shift-v": "editor::Paste",
			"ctrl-shift-x": "editor::Cut",
		},
	},
	{
		"context": "Terminal",
		"bindings": {
			"ctrl-`": "workspace::ToggleBottomDock",
		},
	},
]
